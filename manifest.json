{
  "manifest_version": 3,
  "name": "Visa Sponsorship Checker",
  "version": "1.1.0",
  "description": "Highlights UK licensed sponsors directly on LinkedIn Jobs using an offline Home Office register.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://linkedin.com/jobs/*",
    "https://www.linkedin.com/jobs/*",
    "https://*.linkedin.com/jobs/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_title": "Visa Sponsorship Checker",
    "default_popup": "popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://linkedin.com/jobs/*",
        "https://www.linkedin.com/jobs/*",
        "https://*.linkedin.com/jobs/*"
      ],
      "js": [
        "src/matcher.js",
        "src/url-utils.js",
        "src/content.js"
      ],
      "css": [
        "src/content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "data/uk-sponsors.index.json.gz.part*",
        "data/metadata.json"
      ],
      "matches": [
        "https://linkedin.com/*",
        "https://www.linkedin.com/*",
        "https://*.linkedin.com/*"
      ]
    }
  ]
}
